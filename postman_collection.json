{
    "info": {
        "name": "DevPulse API",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Signup",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test+1@devpulse.com\",\n  \"password\": \"password123\",\n  \"role\": \"contributor\"\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}/api/auth/signup",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "auth",
                        "signup"
                    ]
                }
            }
        },
        {
            "name": "Login",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"email\": \"test+1@devpulse.com\",\n  \"password\": \"password123\"\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}/api/auth/login",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "auth",
                        "login"
                    ]
                }
            }
        },
        {
            "name": "Create Issue",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    },
                    {
                        "key": "Authorization",
                        "value": "{{token}}"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"title\": \"Sample bug\",\n  \"description\": \"Steps to reproduce... long description >=20 chars\",\n  \"type\": \"bug\"\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}/api/issues",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "issues"
                    ]
                }
            }
        },
        {
            "name": "Update Issue",
            "request": {
                "method": "PATCH",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    },
                    {
                        "key": "Authorization",
                        "value": "{{token}}"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"title\": \"Updated title\"\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}/api/issues/1",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "issues",
                        "1"
                    ]
                }
            }
        },
        {
            "name": "Delete Issue",
            "request": {
                "method": "DELETE",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "{{token}}"
                    }
                ],
                "url": {
                    "raw": "{{baseUrl}}/api/issues/1",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "issues",
                        "1"
                    ]
                }
            }
        }
    ],
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:5000"
        },
        {
            "key": "token",
            "value": ""
        }
    ]
}